# Logique Motors — HTTPS reverse proxy (Caddy).
#
# This config uses a real domain, so Caddy automatically provisions and renews a
# Let's Encrypt certificate (no self-signed warning). Requirements:
#   - DNS A record for logique-test.solvara-tech.com → this server.
#   - Ports 80 + 443 reachable from the internet (80 is used for the ACME
#     HTTP-01 challenge and the http→https redirect).
#
# Optional: add an `email` block for Let's Encrypt expiry notifications, e.g.:
#   {
#     email you@example.com
#   }

logique-test.solvara-tech.com {
	encode gzip zstd

	reverse_proxy app:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Redirect plain HTTP -> HTTPS.
:80 {
	redir https://{host}{uri} permanent
}
