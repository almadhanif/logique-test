# Copy this file to .env.local and fill in your values.
# .env.local is gitignored; .env.example is the committed template.

# SQLite database file (created on first migrate/seed)
DATABASE_URL="file:./dev.db"

# Anthropic API key — required for the AI ad-copy feature (Phase 3).
# Free tier is fine: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Simple admin password for /admin (cookie-based auth)
ADMIN_PASSWORD="admin123"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
