# Copy this file to .env.local and fill in your values.
# .env.local is gitignored; .env.example is the committed template.

# SQLite database file (created on first migrate/seed)
DATABASE_URL="file:./dev.db"

# OpenRouter API key — required for the AI features (ad copy + listing analysis).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Optional: override the OpenRouter model id (defaults to "openai/gpt-4o-mini").
# OPENROUTER_MODEL="openai/gpt-4o-mini"

# Simple admin password for /admin (cookie-based auth)
ADMIN_PASSWORD="admin123"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
