// Prisma schema for the Used-Car Listing app.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Lifecycle: DRAFT -> PUBLISHED -> SOLD
enum Status {
  DRAFT
  PUBLISHED
  SOLD
}

// Catalog of vehicle manufacturers (managed by admins). Car.make stores the
// make name as a denormalized string; this table is the dynamic source of truth
// for the make dropdown in the car form and the public filter.
model Make {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Car {
  id          String   @id @default(cuid())
  make        String
  model       String
  year        Int
  mileage     Int
  price       Float
  color       String?
  description String? // Raw, informal description written by the admin
  adCopy      String? // AI-generated polished copy (kept separate from description)
  status      Status   @default(DRAFT)
  images      String? // Comma-separated URLs or a placeholder (no real image storage in this demo)

  // AI Listing Analyzer fields (addon)
  healthScore         Int?      // 0-100 overall marketability score
  suggestedPriceMin   Float?    // AI-suggested price range lower bound
  suggestedPriceMax   Float?    // AI-suggested price range upper bound
  analysisSuggestions String?   // JSON array of suggestions, stored as a string
  lastAnalyzedAt      DateTime? // when the last AI analysis was run

  // Buyer-facing AI insights (cached after first generation)
  buyerInsight   String?   // JSON blob — BuyerInsight
  buyerInsightAt DateTime? // when buyer insight was generated

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([make])
  @@index([price])
}
